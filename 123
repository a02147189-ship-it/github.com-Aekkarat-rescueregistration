        // ทำการประมวลผลเมื่อโหลดเว็บเสร็จ
        window.onload = function() {
            const savedUrl = localStorage.getItem('googleScriptUrl') || '';
            document.getElementById('googleScriptUrl').value = savedUrl;
            document.getElementById('scriptCodeArea').value = googleAppsScriptCode;

            // กำหนดให้ Tab 1 Active ทันทีตอนโหลด
            const firstTabBtn = document.getElementById('btn-tab1');
            if(firstTabBtn) {
               switchTab('tab1', firstTabBtn);
            }

            renderLocalHistory();
            loadSavedForm(); // เปลี่ยนมาเรียกใช้ฟังก์ชันโหลดค่าที่บันทึกไว้แทน
        };

        // --- ส่วนปรับปรุงเพื่อคงค่าข้อมูลในช่อง Input ---

        // บันทึกค่าทุกช่องที่เป็น Input/Select ลง localStorage
        function autoSaveForm() {
            const formData = {};
            document.querySelectorAll('input, select, textarea').forEach(el => {
                if (el.id && el.type !== 'radio') {
                    formData[el.id] = el.value || ""; // ป้องกันกรณีค่า null/undefined เป็นบันทึกค่าว่าง
                } else if (el.type === 'radio' && el.checked) {
                    formData[el.name] = el.value;
                }
            });
            localStorage.setItem('ems_temp_data', JSON.stringify(formData));
        }

        // โหลดค่ากลับเมื่อเปิดเว็บ
        function loadSavedForm() {
            const savedData = JSON.parse(localStorage.getItem('ems_temp_data'));
            if (!savedData) return;

            Object.keys(savedData).forEach(key => {
                const el = document.getElementById(key);
                if (el) {
                    el.value = savedData[key];
                } else {
                    // สำหรับ Radio Button (GCS, Gender)
                    const radio = document.querySelector(`input[name="${key}"][value="${savedData[key]}"]`);
                    if (radio) radio.checked = true;
                }
            });
            
            // เรียกใช้ฟังก์ชันคำนวณใหม่หลังจากโหลดข้อมูล
            calculateGCS();
            analyzeVitalSigns();
            calculateDistances();
        }

        // เพิ่ม Event Listener ให้ทุกช่อง Input
        document.querySelectorAll('input, select, textarea').forEach(el => {
            el.addEventListener('input', autoSaveForm);
        });

        // สลับตารางค่าอ้างอิงของสัญญาณชีพ
        function toggleReferenceTable() {
            const table = document.getElementById('referenceTable');
            table.classList.toggle('hidden');
        }

        // ระบบสลับแท็บ (Tab Navigation System)
        function switchTab(tabId, clickedBtn) {
            // ซ่อนเนื้อหาทุกแท็บ
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('block');
                tab.classList.add('hidden');
            });
            
            // แสดงเนื้อหาแท็บที่เลือก
            document.getElementById(tabId).classList.remove('hidden');
            document.getElementById(tabId).classList.add('block');

            // ล้าง Style ปุ่มแท็บทั้งหมดให้เป็นสถานะ Inactive
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.className = "tab-btn whitespace-nowrap px-4 py-2.5 rounded-t-xl font-bold text-sm transition-all bg-slate-50 text-slate-500 hover:bg-slate-100 border-t border-x border-slate-200 flex items-center gap-2";
            });
            
            // ปรับ Style ปุ่มที่ถูกคลิกให้เป็นสถานะ Active
            if(clickedBtn) {
                clickedBtn.className = "tab-btn whitespace-nowrap px-4 py-2.5 rounded-t-xl font-bold text-sm transition-all bg-blue-600 text-white shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] border-t border-x border-blue-600 flex items-center gap-2";
            }
        }

        // เปิด/ปิด การตั้งค่าเชื่อมต่อชีท
        function toggleSettingsModal() {
            const modal = document.getElementById('settingsModal');
            modal.classList.toggle('hidden');
        }

        // เซฟการตั้งค่าชีทลง Local Storage
        function saveSettings() {
            const urlInput = document.getElementById('googleScriptUrl').value.trim();
            localStorage.setItem('googleScriptUrl', urlInput);
            showToast("บันทึกการเชื่อมตั้งค่า Google Sheet เรียบร้อย", "success");
            toggleSettingsModal();
        }

        // คัดลอกโค้ด Apps Script
        function copyScriptCode() {
            const copyText = document.getElementById("scriptCodeArea");
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            document.execCommand("copy");
            showToast("คัดลอกโค้ดสคริปต์ไปยัง Clipboard แล้ว", "info");
        }

        // การแสดงระบบแจ้งเตือนผลสำเร็จ/เตือน (Toast Notification)
        function showToast(message, type = "info") {
            const toast = document.getElementById('toast');
            const content = document.getElementById('toast-content');
            const text = document.getElementById('toast-text');
            
            if (type === "success") {
                content.className = "bg-slate-900 border-l-4 border-emerald-500 text-white px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-2.5 border-y border-r border-slate-800 font-bold text-xs";
            } else if (type === "error") {
                content.className = "bg-slate-900 border-l-4 border-rose-500 text-white px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-2.5 border-y border-r border-slate-800 font-bold text-xs";
            } else {
                content.className = "bg-slate-900 border-l-4 border-indigo-500 text-white px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-2.5 border-y border-r border-slate-800 font-bold text-xs";
            }

            text.innerText = message;
            toast.className = "fixed top-4 right-4 z-50 transform translate-y-0 opacity-100 transition-all duration-300";
            
            setTimeout(() => {
                toast.className = "fixed top-4 right-4 z-50 transform translate-y-[-100px] opacity-0 transition-all duration-300 pointer-events-none";
            }, 3000);
        }

        // ฟังก์ชันประทับเวลาตอนนี้ลงช่องฟิลด์
        function stampCurrentTime(timeInputId) {
            const timeInput = document.getElementById(timeInputId);
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            timeInput.value = `${year}-${month}-${day}T${hours}:${minutes}`;
            showToast("ประทับเวลาปฏิบัติการเรียบร้อย", "success");
            calculateDistances();
            autoSaveForm();
        }

        // ฟังก์ชันประทับเวลาจากเหตุการณ์การกรอกเลขไมล์สะสม
        function handleOdoInput(odoId, timeId) {
            const odoInput = document.getElementById(odoId);
            const timeInput = document.getElementById(timeId);
            
            if (odoInput.value.trim() !== "" && !timeInput.value) {
                const now = new Date();
                const year = now.getFullYear();
                const month = String(now.getMonth() + 1).padStart(2, '0');
                const day = String(now.getDate()).padStart(2, '0');
                const hours = String(now.getHours()).padStart(2, '0');
                const minutes = String(now.getMinutes()).padStart(2, '0');
                timeInput.value = `${year}-${month}-${day}T${hours}:${minutes}`;
                showToast("ประทับเวลาจากเลขไมล์สะสมโดยอัตโนมัติ", "info");
            }
            calculateDistances();
            autoSaveForm();
        }

        // ประมวลผลและคำนวณข้อมูลเวลา & ระยะทางของเหตุการณ์ทั้งหมด
        function calculateDistances() {
            const odoDep = parseFloat(document.getElementById('odoDepart').value);
            const odoScene = parseFloat(document.getElementById('odoArriveScene').value);
            const odoHosp = parseFloat(document.getElementById('odoArriveHospital').value);
            const odoRet = parseFloat(document.getElementById('odoReturn').value);

            // 1. ตรวจสอบและประมวลผลช่วงออกจุดจอด -> ถึงจุดเกิดเหตุ
            const timeDepartVal = document.getElementById('timeDepart').value;
            const timeArrSceneVal = document.getElementById('timeArriveScene').value;
            const toSceneTimeBadge = document.getElementById('toSceneTimeBadge');
            
            if (toSceneTimeBadge) {
                if (timeDepartVal && timeArrSceneVal) {
                    const diffMs = new Date(timeArrSceneVal) - new Date(timeDepartVal);
                    if (diffMs >= 0) {
                        toSceneTimeBadge.innerText = `${Math.round(diffMs / 60000)} นาที`;
                        toSceneTimeBadge.className = "text-[9px] font-bold text-blue-700 bg-blue-100 px-1.5 py-0.5 rounded border border-blue-200";
                    } else {
                        toSceneTimeBadge.innerText = "เวลาไม่สอดคล้อง";
                        toSceneTimeBadge.className = "text-[9px] font-bold text-rose-700 bg-rose-100 px-1.5 py-0.5 rounded border border-rose-200";
                    }
                } else {
                    toSceneTimeBadge.innerText = "- นาที";
                    toSceneTimeBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            const sceneDistBadge = document.getElementById('sceneDistBadge');
            if (sceneDistBadge) {
                if (!isNaN(odoDep) && !isNaN(odoScene) && odoScene >= odoDep) {
                    sceneDistBadge.innerText = `${(odoScene - odoDep).toFixed(1)} กม.`;
                    sceneDistBadge.className = "text-[9px] font-bold text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded border border-amber-200";
                } else {
                    sceneDistBadge.innerText = "0.0 กม.";
                    sceneDistBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            // 2. ระยะจอด ณ จุดเกิดเหตุ (ถึงจุดเกิดเหตุ -> ออกจากจุดเกิดเหตุ)
            const timeDepSceneVal = document.getElementById('timeDepartScene').value;
            const sceneTimeBadge = document.getElementById('sceneTimeBadge');
            if (sceneTimeBadge) {
                if (timeArrSceneVal && timeDepSceneVal) {
                    const diffMs = new Date(timeDepSceneVal) - new Date(timeArrSceneVal);
                    if (diffMs >= 0) {
                        sceneTimeBadge.innerText = `จอด ${Math.round(diffMs / 60000)} นาที`;
                        sceneTimeBadge.className = "text-[9px] font-bold text-rose-700 bg-rose-100 px-1.5 py-0.5 rounded border border-rose-200";
                    } else {
                        sceneTimeBadge.innerText = "เวลาไม่สอดคล้อง";
                        sceneTimeBadge.className = "text-[9px] font-bold text-rose-700 bg-rose-100 px-1.5 py-0.5 rounded border border-rose-200";
                    }
                } else {
                    sceneTimeBadge.innerText = "- นาที";
                    sceneTimeBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            // 3. ระยะเวลานำส่ง รพ. (ออกจากจุดเกิดเหตุ -> ถึง รพ.)
            const timeArriveHospitalVal = document.getElementById('timeArriveHospital').value;
            const hospitalTimeBadge = document.getElementById('hospitalTimeBadge');
            if (hospitalTimeBadge) {
                if (timeDepSceneVal && timeArriveHospitalVal) {
                    const diffMs = new Date(timeArriveHospitalVal) - new Date(timeDepSceneVal);
                    if (diffMs >= 0) {
                        hospitalTimeBadge.innerText = `วิ่ง ${Math.round(diffMs / 60000)} นาที`;
                        hospitalTimeBadge.className = "text-[9px] font-bold text-indigo-700 bg-indigo-100 px-1.5 py-0.5 rounded border border-indigo-200";
                    } else {
                        hospitalTimeBadge.innerText = "เวลาไม่สอดคล้อง";
                        hospitalTimeBadge.className = "text-[9px] font-bold text-rose-700 bg-rose-100 px-1.5 py-0.5 rounded border border-rose-200";
                    }
                } else {
                    hospitalTimeBadge.innerText = "- นาที";
                    hospitalTimeBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            const hospitalDistBadge = document.getElementById('hospitalDistBadge');
            if (hospitalDistBadge) {
                if (!isNaN(odoScene) && !isNaN(odoHosp) && odoHosp >= odoScene) {
                    hospitalDistBadge.innerText = `${(odoHosp - odoScene).toFixed(1)} กม.`;
                    hospitalDistBadge.className = "text-[9px] font-bold text-blue-700 bg-blue-100 px-1.5 py-0.5 rounded border border-blue-200";
                } else {
                    hospitalDistBadge.innerText = "0.0 กม.";
                    hospitalDistBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            // 4. คำนวณช่วงจอดทำเคสที่ รพ. (ถึง รพ. -> ออกจาก รพ. *ปุ่มประทับเวลาอย่างเดียว*)
            const timeDepartHospitalVal = document.getElementById('timeDepartHospital').value;
            const hospitalWaitTimeBadge = document.getElementById('hospitalWaitTimeBadge');
            if (hospitalWaitTimeBadge) {
                if (timeArriveHospitalVal && timeDepartHospitalVal) {
                    const diffMs = new Date(timeDepartHospitalVal) - new Date(timeArriveHospitalVal);
                    if (diffMs >= 0) {
                        hospitalWaitTimeBadge.innerText = `จอด รพ. ${Math.round(diffMs / 60000)} นาที`;
                        hospitalWaitTimeBadge.className = "text-[9px] font-bold text-teal-700 bg-teal-100 px-1.5 py-0.5 rounded border border-teal-200";
                    } else {
                        hospitalWaitTimeBadge.innerText = "เวลาไม่สอดคล้อง";
                        hospitalWaitTimeBadge.className = "text-[9px] font-bold text-rose-700 bg-rose-100 px-1.5 py-0.5 rounded border border-rose-200";
                    }
                } else {
                    hospitalWaitTimeBadge.innerText = "- นาที";
                    hospitalWaitTimeBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }

            // 5. ประมวลผลและแสดงผลรวมระยะทางเดินทางวิ่งสะสมทั้งหมดของเคส
            const totalDistBadge = document.getElementById('totalDistBadge');
            if (totalDistBadge) {
                if (!isNaN(odoDep) && !isNaN(odoRet) && odoRet >= odoDep) {
                    totalDistBadge.innerText = `รวม ${(odoRet - odoDep).toFixed(1)} กม.`;
                    totalDistBadge.className = "text-[9px] font-black text-emerald-800 bg-emerald-100 px-1.5 py-0.5 rounded border border-emerald-200";
                } else {
                    totalDistBadge.innerText = "รวม 0 กม.";
                    totalDistBadge.className = "text-[9px] font-bold text-slate-500 bg-slate-200/80 px-1.5 py-0.5 rounded";
                }
            }
        }

        // ระบบประมวลคะแนนผลสติสัมปชัญญะ (Glasgow Coma Scale)
        function calculateGCS() {
            const eRadio = document.querySelector('input[name="gcs_e"]:checked');
            const vRadio = document.querySelector('input[name="gcs_v"]:checked');
            const mRadio = document.querySelector('input[name="gcs_m"]:checked');

            // ป้องกัน error กรณี radio ยังไม่ถูก load
            const eVal = eRadio ? parseInt(eRadio.value) : 4;
            const vVal = vRadio ? parseInt(vRadio.value) : 5;
            const mVal = mRadio ? parseInt(mRadio.value) : 6;
            const total = eVal + vVal + mVal;
            
            document.getElementById('gcsEValue').innerText = eVal + " คะแนน";
            document.getElementById('gcsVValue').innerText = vVal + " คะแนน";
            document.getElementById('gcsMValue').innerText = mVal + " คะแนน";
            document.getElementById('gcsTotalDisplay').innerText = total;

            const severityDisplay = document.getElementById('gcsSeverityDisplay');
            if (total === 15) {
                severityDisplay.innerText = "ปกติ (Normal)";
                severityDisplay.className = "text-xs font-bold bg-emerald-100 text-emerald-800 px-2.5 py-1 rounded-lg ml-1 border border-emerald-200";
            } else if (total >= 13) {
                severityDisplay.innerText = "ประเมินบกพร่องเล็กน้อย (Mild Injury)";
                severityDisplay.className = "text-xs font-bold bg-sky-100 text-sky-800 px-2.5 py-1 rounded-lg ml-1 border border-sky-200";
            } else if (total >= 9) {
                severityDisplay.innerText = "บกพร่องปานกลาง (Moderate Severe)";
                severityDisplay.className = "text-xs font-bold bg-amber-100 text-amber-800 px-2.5 py-1 rounded-lg ml-1 border border-amber-200";
            } else {
                severityDisplay.innerText = "วิกฤตหมดสติ (Severe Coma)";
                severityDisplay.className = "text-xs font-bold bg-rose-100 text-rose-800 px-2.5 py-1 rounded-lg ml-1 border border-rose-200 animate-pulse";
            }

            // บังคับเปลี่ยนสไตล์ขอบการเลือก GCS
            const allOptions = document.querySelectorAll('.gcs-option');
            allOptions.forEach(opt => {
                const isChecked = opt.querySelector('input').checked;
                if (isChecked) {
                    opt.classList.add('border-indigo-500', 'bg-indigo-50/20', 'ring-2', 'ring-indigo-500/10');
                } else {
                    opt.classList.remove('border-indigo-500', 'bg-indigo-50/20', 'ring-2', 'ring-indigo-500/10');
                }
            });

            autoSaveForm();
        }

        // ระบบแปลความหมายวิเคราะห์ผลของสัญญาณชีพแรกรับแบบเรียลไทม์
        function analyzeVitalSigns() {
            const sys = parseInt(document.getElementById('bpSystolic').value);
            const dia = parseInt(document.getElementById('bpDiastolic').value);
            const bpStatus = document.getElementById('bpStatus');
            
            if (isNaN(sys) || isNaN(dia)) {
                bpStatus.innerText = "ไม่มีข้อมูล";
                bpStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-slate-200 text-slate-600 border border-transparent";
            } else {
                if (sys < 90 || dia < 60) {
                    bpStatus.innerText = "ความดันต่ำ (Hypotension)";
                    bpStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-rose-100 text-rose-700 border border-rose-200 animate-pulse";
                } else if (sys >= 140 || dia >= 90) {
                    bpStatus.innerText = "ความดันสูง (Hypertension)";
                    bpStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200";
                } else {
                    bpStatus.innerText = "ปกติ";
                    bpStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200";
                }
            }

            const pulse = parseInt(document.getElementById('pulseRate').value);
            const pulseStatus = document.getElementById('pulseStatus');
            if (isNaN(pulse)) {
                pulseStatus.innerText = "ไม่มีข้อมูล";
                pulseStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-slate-200 text-slate-600 border border-transparent";
            } else {
                if (pulse < 60) {
                    pulseStatus.innerText = "ชีพจรช้า (Bradycardia)";
                    pulseStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200";
                } else if (pulse > 100) {
                    pulseStatus.innerText = "ชีพจรเร็ว (Tachycardia)";
                    pulseStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-rose-100 text-rose-700 border border-rose-200 animate-pulse";
                } else {
                    pulseStatus.innerText = "ปกติ";
                    pulseStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200";
                }
            }

            const spo2Val = parseInt(document.getElementById('spo2').value);
            const spo2Status = document.getElementById('spo2Status');
            if (isNaN(spo2Val)) {
                spo2Status.innerText = "ไม่มีข้อมูล";
                spo2Status.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-slate-200 text-slate-600 border border-transparent";
            } else {
                if (spo2Val < 90) {
                    spo2Status.innerText = "วิกฤต! ออกซิเจนต่ำมาก";
                    spo2Status.className = "mt-3 text-center py-1 rounded-lg text-xs font-extrabold bg-red-200 text-red-800 border border-red-300 animate-bounce";
                } else if (spo2Val < 95) {
                    spo2Status.innerText = "ออกซิเจนเริ่มต่ำ (Hypoxia)";
                    spo2Status.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-rose-100 text-rose-700 border border-rose-200 animate-pulse";
                } else {
                    spo2Status.innerText = "ปกติ";
                    spo2Status.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200";
                }
            }

            const dtxVal = parseInt(document.getElementById('dtx').value);
            const dtxStatus = document.getElementById('dtxStatus');
            if (isNaN(dtxVal)) {
                dtxStatus.innerText = "ไม่มีข้อมูล";
                dtxStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-slate-200 text-slate-600 border border-transparent";
            } else {
                if (dtxVal < 70) {
                    dtxStatus.innerText = "น้ำตาลต่ำ (Hypoglycemia)";
                    dtxStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-rose-100 text-rose-700 border border-rose-200 animate-pulse";
                } else if (dtxVal > 180) {
                    dtxStatus.innerText = "น้ำตาลสูงผิดปกติ";
                    dtxStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200";
                } else {
                    dtxStatus.innerText = "ปกติ";
                    dtxStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200";
                }
            }

            const rrVal = parseInt(document.getElementById('respiratoryRate').value);
            const rrStatus = document.getElementById('rrStatus');
            if (isNaN(rrVal)) {
                rrStatus.innerText = "ไม่มีข้อมูล";
                rrStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-slate-200 text-slate-600 border border-transparent";
            } else {
                if (rrVal < 12) {
                    rrStatus.innerText = "หายใจช้าผิดปกติ";
                    rrStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-rose-100 text-rose-700 border border-rose-200";
                } else if (rrVal > 20) {
                    rrStatus.innerText = "หายใจหอบเร็ว (Tachypnea)";
                    rrStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200 animate-pulse";
                } else {
                    rrStatus.innerText = "ปกติ";
                    rrStatus.className = "mt-3 text-center py-1 rounded-lg text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200";
                }
            }
        }

        // จัดรวมข้อมูลในหน้าฟอร์มเพื่อส่งต่อประมวลผล
        function getFormData() {
            // ฟังก์ชันช่วยเหลือสำหรับตรวจสอบค่าว่างก่อนส่ง
            const getVal = (id) => {
                const el = document.getElementById(id);
                return el ? el.value.trim() : "";
            };

            const genderRadio = document.querySelector('input[name="patientGender"]:checked');
            const gender = genderRadio ? genderRadio.value : "";
            const patientAge = getVal('patientAge');
            const caseSeverity = getVal('caseSeverity');
            const chiefComplaint = getVal('chiefComplaint');

            // ข้อมูลเดินทาง เลขไมล์ และเวลา
            const odoDepart = getVal('odoDepart');
            const timeDepart = getVal('timeDepart');
            const odoArriveScene = getVal('odoArriveScene');
            const timeArriveScene = getVal('timeArriveScene');
            const odoDepartScene = ""; // ยกเลิกการใช้งาน
            const timeDepartScene = getVal('timeDepartScene');
            const odoArriveHospital = getVal('odoArriveHospital');
            const timeArriveHospital = getVal('timeArriveHospital');
            const timeDepartHospital = getVal('timeDepartHospital');
            const odoReturn = getVal('odoReturn');
            const timeReturn = getVal('timeReturn');

            // สัญญาณชีพ
            const bpSystolic = getVal('bpSystolic');
            const bpDiastolic = getVal('bpDiastolic');
            const pulse = getVal('pulseRate');
            const spo2 = getVal('spo2');
            const dtx = getVal('dtx');
            const rr = getVal('respiratoryRate');

            // GCS
            const eRadio = document.querySelector('input[name="gcs_e"]:checked');
            const vRadio = document.querySelector('input[name="gcs_v"]:checked');
            const mRadio = document.querySelector('input[name="gcs_m"]:checked');
            
            const gcsE = eRadio ? parseInt(eRadio.value) : 4;
            const gcsV = vRadio ? parseInt(vRadio.value) : 5;
            const gcsM = mRadio ? parseInt(mRadio.value) : 6;
            const gcsTotal = gcsE + gcsV + gcsM;
            const gcsInterpret = document.getElementById('gcsSeverityDisplay').innerText;

            const mrcArmL = getVal('mrc_arm_l');
            const mrcArmR = getVal('mrc_arm_r');
            const mrcLegL = getVal('mrc_leg_l');
            const mrcLegR = getVal('mrc_leg_r');

            return {
                gender, patientAge, caseSeverity, chiefComplaint,
                odoDepart, timeDepart, odoArriveScene, timeArriveScene,
                odoDepartScene, timeDepartScene,
                odoArriveHospital, timeArriveHospital, timeDepartHospital,
                odoReturn, timeReturn,
                bpSystolic, bpDiastolic, pulse, spo2, dtx, rr,
                gcsE, gcsV, gcsM, gcsTotal, gcsInterpret,
                mrcArmL, mrcArmR, mrcLegL, mrcLegR
            };
        }

        // เรียบเรียงและสรุปข้อมูล (SBAR Structure) สำหรับ Copy วางกลุ่มรายงาน
        function compileSbarText(data) {
            const formattedDate = new Date().toLocaleString('th-TH', { 
                year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' 
            });

            const formatLocalTime = (isoString) => {
                if (!isoString) return "ไม่ได้ระบุ";
                return new Date(isoString).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) + " น.";
            };

            const bpText = (data.bpSystolic && data.bpDiastolic) ? `${data.bpSystolic}/${data.bpDiastolic} mmHg` : "ไม่ได้ระบุ";
            const pulseText = data.pulse ? `${data.pulse} ครั้ง/นาที` : "ไม่ได้ระบุ";
            const spo2Text = data.spo2 ? `${data.spo2} %` : "ไม่ได้ระบุ";
            const dtxText = data.dtx ? `${data.dtx} mg/dL` : "ไม่ได้ระบุ";
            const rrText = data.rr ? `${data.rr} ครั้ง/นาที` : "ไม่ได้ระบุ";

            // สรุปยอดระยะทางเดินทาง
            let distScene = "-";
            if (data.odoDepart && data.odoArriveScene) distScene = (parseFloat(data.odoArriveScene) - parseFloat(data.odoDepart)).toFixed(1);
            
            let distHosp = "-";
            if (data.odoArriveScene && data.odoArriveHospital) distHosp = (parseFloat(data.odoArriveHospital) - parseFloat(data.odoArriveScene)).toFixed(1);
            
            let distTotal = "-";
            if (data.odoDepart && data.odoReturn) distTotal = (parseFloat(data.odoReturn) - parseFloat(data.odoDepart)).toFixed(1);

            let timeToScene = "-";
            if (data.timeDepart && data.timeArriveScene) {
                const diffMs = new Date(data.timeArriveScene) - new Date(data.timeDepart);
                if (diffMs >= 0) timeToScene = `${Math.round(diffMs / 60000)} นาที`;
            }

            let timeOnScene = "-";
            if (data.timeArriveScene && data.timeDepartScene) {
                const diffMs = new Date(data.timeDepartScene) - new Date(data.timeArriveScene);
                if (diffMs >= 0) timeOnScene = `${Math.round(diffMs / 60000)} นาที`;
            }

            let timeTransport = "-";
            if (data.timeDepartScene && data.timeArriveHospital) {
                const diffMs = new Date(data.timeArriveHospital) - new Date(data.timeDepartScene);
                if (diffMs >= 0) timeTransport = `${Math.round(diffMs / 60000)} นาที`;
            }

            let timeAtHospital = "-";
            if (data.timeArriveHospital && data.timeDepartHospital) {
                const diffMs = new Date(data.timeDepartHospital) - new Date(data.timeArriveHospital);
                if (diffMs >= 0) timeAtHospital = `${Math.round(diffMs / 60000)} นาที`;
            }

            return `=== รายงานสรุปปฏิบัติการกู้ชีพ (SBAR Report) ===
[S - Situation & General Info]
- วัน-เวลาปฏิบัติงาน: ${formattedDate}
- ความเร่งด่วน: ${data.caseSeverity || "ไม่ได้ระบุ"}
- ข้อมูลทั่วไป: เพศ ${data.gender || "ไม่ได้ระบุ"}, อายุ ${data.patientAge || "ไม่ได้ระบุ"} ปี
- อาการสำคัญ: ${data.chiefComplaint || "ไม่ได้ระบุ"}

[B - Background & Operational Timeline]
- 1. ออกจากฐาน: ${formatLocalTime(data.timeDepart)} (ไมล์สะสม: ${data.odoDepart || "-"})
- 2. ถึงที่เกิดเหตุ: ${formatLocalTime(data.timeArriveScene)} (ไมล์สะสม: ${data.odoArriveScene || "-"})
  └─ [เวลาเดินทางไป: ${timeToScene} | ระยะทางช่วงแรก: ${distScene} กม.]
- 3. ออกจากจุดเกิดเหตุ: ${formatLocalTime(data.timeDepartScene)}
  └─ [ระยะจอดปฏิบัติการที่เกิดเหตุ: ${timeOnScene}]
- 4. ถึงโรงพยาบาล: ${formatLocalTime(data.timeArriveHospital)} (ไมล์สะสม: ${data.odoArriveHospital || "-"})
  └─ [เวลานำส่ง รพ.: ${timeTransport} | ระยะนำส่ง: ${distHosp} กม.]
- 5. ออกจากโรงพยาบาล: ${formatLocalTime(data.timeDepartHospital)} (*ประทับเวลา*)
  └─ [ระยะจอดทำเคส/ส่งมอบงานที่ รพ.: ${timeAtHospital}]
- 6. กลับฐาน/เคสใหม่: ${formatLocalTime(data.timeReturn)} (ไมล์สะสม: ${data.odoReturn || "-"})
  └─ [รวมระยะวิ่งทั้งสิ้น: ${distTotal} กม.]

[A - Assessment & Vital Signs]
- ความดันโลหิต (BP): ${bpText}
- ชีพจร (Pulse): ${pulseText}
- ออกซิเจนปลายนิ้ว (SpO2): ${spo2Text}
- น้ำตาลปลายนิ้ว (DTX): ${dtxText}
- อัตราการหายใจ (RR): ${rrText}
- คะแนนรู้สึกตัว GCS: ${data.gcsTotal}/15 คะแนน (E${data.gcsE} V${data.gcsV} M${data.gcsM}) -> ${data.gcsInterpret}
- กำลังกล้ามเนื้อ (MRC Scale):
  └─ แขน: ซ้าย Grade ${data.mrcArmL}/5 | ขวา Grade ${data.mrcArmR}/5
  └─ ขา: ซ้าย Grade ${data.mrcLegL}/5 | ขวา Grade ${data.mrcLegR}/5

[R - Recommendation / Action Taken]
- สังเกตอาการและส่งต่อทีมแพทย์โรงพยาบาลเป้าหมายเรียบร้อย
=======================================`;
        }

        // แสดงผลตัวอย่างผลลัพธ์
        function generatePreviewText() {
            const data = getFormData();
            const text = compileSbarText(data);
            document.getElementById('previewTextarea').value = text;
            document.getElementById('previewModal').classList.remove('hidden');
        }

        function closePreviewModal() {
            document.getElementById('previewModal').classList.add('hidden');
        }

        // คัดลอกข้อมูลเข้าคลิปบอร์ดสำหรับแชร์
        function copyToClipboard() {
            const copyText = document.getElementById("previewTextarea");
            const tempTextarea = document.createElement("textarea");
            tempTextarea.value = copyText.value;
            document.body.appendChild(tempTextarea);
            tempTextarea.select();
            
            try {
                document.execCommand("copy");
                showToast("คัดลอกสรุปเคสไปยังคลิปบอร์ดเรียบร้อย!", "success");
            } catch (err) {
                showToast("คัดลอกไม่สำเร็จ กรุณาคัดลอกด้วยตนเอง", "error");
            }
            
            document.body.removeChild(tempTextarea);
            closePreviewModal();
        }

        // ประมวลผลและนำส่งบันทึกเคส
        function handleFormSubmit(event) {
            event.preventDefault();

            const submitBtn = document.getElementById('submitBtn');
            const data = getFormData();
            const googleScriptUrl = localStorage.getItem('googleScriptUrl') || '';

            saveToLocalHistory(data);

            if (!googleScriptUrl) {
                showToast("บันทึกเคสลงในประวัติของเครื่องเรียบร้อย (ยังไม่เชื่อมต่อ Google Sheets)", "info");
                scrollToHistory();
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerText = "กำลังทำการจัดส่งข้อมูลขึ้น Google Sheets...";

            fetch(googleScriptUrl, {
                method: "POST",
                mode: "no-cors",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            })
            .then(() => {
                showToast("บันทึกและส่งเข้า Google Sheet สำเร็จเรียบร้อย!", "success");
                submitBtn.disabled = false;
                submitBtn.innerHTML = `
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg> ส่งข้อมูลขึ้น Sheet (เฉพาะที่กรอก)`;
                scrollToHistory();
            })
            .catch(error => {
                showToast("เกิดข้อผิดพลาดในการนำส่งข้อมูล: " + error.toString(), "error");
                submitBtn.disabled = false;
                submitBtn.innerHTML = `
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg> ส่งข้อมูลขึ้น Sheet (เฉพาะที่กรอก)`;
            });
        }

        function scrollToHistory() {
            document.getElementById('historySection').scrollIntoView({ behavior: 'smooth' });
        }

        // ฟังก์ชันเก็บรักษาข้อมูลใน Local Storage ย้อนหลังในเครื่อง
        function saveToLocalHistory(data) {
            let history = [];
            try {
                history = JSON.parse(localStorage.getItem('ems_history')) || [];
            } catch(e) {
                history = [];
            }

            data.uid = Date.now().toString(); 
            data.timestamp = new Date().toISOString();
            history.unshift(data);

            if (history.length > 10) {
                history = history.slice(0, 10);
            }

            localStorage.setItem('ems_history', JSON.stringify(history));
            renderLocalHistory();
        }

        // เรนเดอร์ตารางเคสประวัติปฏิบัติการย้อนหลัง
        function renderLocalHistory() {
            let history = [];
            try {
                history = JSON.parse(localStorage.getItem('ems_history')) || [];
            } catch(e) {
                history = [];
            }

            const tbody = document.getElementById('historyTableBody');
            
            if (history.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="p-6 text-center text-slate-400 font-medium">ยังไม่มีประวัติการบันทึกข้อมูลเคสบนอุปกรณ์นี้</td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = '';
            history.forEach(item => {
                const recordDate = item.timestamp ? new Date(item.timestamp) : new Date();
                const formattedDate = recordDate.toLocaleString('th-TH', {
                    month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
                });

                const bpStr = (item.bpSystolic && item.bpDiastolic) ? `${item.bpSystolic}/${item.bpDiastolic}` : "-";
                const pStr = item.pulse || "-";
                const o2Str = item.spo2 || "-";
                const dtxStr = item.dtx || "-";
                const rrStr = item.rr || "-";

                let distanceText = "- กม.";
                if (item.odoDepart && item.odoReturn) {
                    distanceText = `${(parseFloat(item.odoReturn) - parseFloat(item.odoDepart)).toFixed(1)} กม.`;
                }

                const severityColors = {
                    "Non-Urgent": "text-slate-600 bg-slate-100 border-slate-200",
                    "Urgent": "text-amber-700 bg-amber-50 border-amber-200",
                    "Emergency": "text-rose-700 bg-rose-50 border-rose-200 animate-pulse"
                };
                const caseSeverity = item.caseSeverity || "ไม่ได้ระบุ";
                const severityClass = severityColors[caseSeverity] || "text-slate-600 bg-slate-100 border-slate-200";

                const chiefComplaint = item.chiefComplaint || "ไม่ได้ระบุอาการ";
                const shortComplaint = chiefComplaint.length > 25 ? chiefComplaint.substring(0, 25) + '...' : chiefComplaint;

                const row = document.createElement('tr');
                row.className = "hover:bg-slate-50 border-b border-slate-100 transition-colors text-xs";
                row.innerHTML = `
                    <td class="p-3 text-slate-500 font-bold">${formattedDate}</td>
                    <td class="p-3">
                        <div class="font-extrabold text-slate-800">ผู้ป่วย (เพศ: ${item.gender || "-"})</div>
                        <div class="text-[10px] text-slate-500 font-medium mt-0.5">อายุ: ${item.patientAge || "-"} ปี | อาการ: ${shortComplaint}</div>
                        <span class="inline-block text-[9px] px-1.5 py-0.5 rounded font-bold border mt-1 ${severityClass}">${caseSeverity}</span>
                    </td>
                    <td class="p-3 font-semibold text-slate-700">
                        BP: <span class="text-slate-900">${bpStr}</span> | HR: <span class="text-slate-900">${pStr}</span> | SpO2: <span class="text-blue-600">${o2Str}%</span><br>
                        <span class="text-[10px] text-slate-400 font-medium">DTX: ${dtxStr} mg/dL | RR: ${rrStr} ครั้ง/นาที</span>
                    </td>
                    <td class="p-3 font-bold text-slate-700">
                        <span>ระยะวิ่งสะสม: ${distanceText}</span><br>
                        <span class="text-[10px] text-slate-400 font-medium">ไมล์ออก: ${item.odoDepart || "-"} -> กลับฐาน: ${item.odoReturn || "-"}</span>
                    </td>
                    <td class="p-3">
                        <div class="font-bold">GCS: <strong class="text-indigo-600">${item.gcsTotal || "15"}/15</strong> <span class="text-[10px] text-slate-400">(E${item.gcsE||4} V${item.gcsV||5} M${item.gcsM||6})</span></div>
                        <div class="text-[10px] text-teal-600 font-bold mt-0.5">MRC แขน: ${item.mrcArmL||5}/${item.mrcArmR||5} | ขา: ${item.mrcLegL||5}/${item.mrcLegR||5}</div>
                    </td>
                    <td class="p-3 text-center">
                        <button type="button" onclick="loadCaseFromHistory('${item.uid}')" class="text-blue-600 hover:text-blue-800 font-extrabold bg-blue-50 hover:bg-blue-100 border border-blue-200 px-2.5 py-1.5 rounded-lg transition-all">ดึงข้อมูลคืนฟอร์ม</button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // ฟังก์ชันดึงประวัติข้อมูลเคสเก่าคืนเพื่อแก้ไขงานหรือดูข้อมูลซ้ำ
        function loadCaseFromHistory(uid) {
            let history = [];
            try {
                history = JSON.parse(localStorage.getItem('ems_history')) || [];
            } catch(e) {}

            const caseData = history.find(item => item.uid === uid);
            if (!caseData) return;

            const genderRadios = document.querySelectorAll('input[name="patientGender"]');
            genderRadios.forEach(radio => {
                if (radio.value === caseData.gender) radio.checked = true;
            });

            document.getElementById('patientAge').value = caseData.patientAge || "";
            document.getElementById('caseSeverity').value = caseData.caseSeverity || "Urgent";
            document.getElementById('chiefComplaint').value = caseData.chiefComplaint || "";

            // คืนค่าข้อมูลไมล์สะสมและจุดประทับเวลา
            document.getElementById('odoDepart').value = caseData.odoDepart || "";
            document.getElementById('timeDepart').value = caseData.timeDepart || "";
            document.getElementById('odoArriveScene').value = caseData.odoArriveScene || "";
            document.getElementById('timeArriveScene').value = caseData.timeArriveScene || "";
            document.getElementById('timeDepartScene').value = caseData.timeDepartScene || "";
            document.getElementById('odoArriveHospital').value = caseData.odoArriveHospital || "";
            document.getElementById('timeArriveHospital').value = caseData.timeArriveHospital || "";
            document.getElementById('timeDepartHospital').value = caseData.timeDepartHospital || ""; 
            document.getElementById('odoReturn').value = caseData.odoReturn || "";
            document.getElementById('timeReturn').value = caseData.timeReturn || "";

            // สัญญาณชีพ
            document.getElementById('bpSystolic').value = caseData.bpSystolic || "";
            document.getElementById('bpDiastolic').value = caseData.bpDiastolic || "";
            document.getElementById('pulseRate').value = caseData.pulse || "";
            document.getElementById('spo2').value = caseData.spo2 || "";
            document.getElementById('dtx').value = caseData.dtx || "";
            document.getElementById('respiratoryRate').value = caseData.rr || "";

            const eRadios = document.querySelectorAll('input[name="gcs_e"]');
            eRadios.forEach(r => { if (parseInt(r.value) === caseData.gcsE) r.checked = true; });

            const vRadios = document.querySelectorAll('input[name="gcs_v"]');
            vRadios.forEach(r => { if (parseInt(r.value) === caseData.gcsV) r.checked = true; });

            const mRadios = document.querySelectorAll('input[name="gcs_m"]');
            mRadios.forEach(r => { if (parseInt(r.value) === caseData.gcsM) r.checked = true; });

            document.getElementById('mrc_arm_l').value = caseData.mrcArmL || "5";
            document.getElementById('mrc_arm_r').value = caseData.mrcArmR || "5";
            document.getElementById('mrc_leg_l').value = caseData.mrcLegL || "5";
            document.getElementById('mrc_leg_r').value = caseData.mrcLegR || "5";

            calculateGCS();
            analyzeVitalSigns();
            calculateDistances();
            autoSaveForm();
            
            showToast("ดึงประวัติข้อมูลคืนสู่ฟอร์มเรียบร้อย", "info");
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ล้างประวัติภายในเครื่องทั้งหมด
        function clearLocalHistory() {
            localStorage.removeItem('ems_history');
            renderLocalHistory();
            showToast("ล้างข้อมูลประวัติทั้งหมดสำเร็จเรียบร้อย", "info");
        }

        // ระบบล้างแบบฟอร์มและการยืนยันผ่าน Modal
        function resetFormToDefault() {
            document.getElementById('confirmModal').classList.remove('hidden');
        }

        function closeConfirmModal() {
            document.getElementById('confirmModal').classList.add('hidden');
        }

        function executeResetForm() {
            document.getElementById("emsForm").reset();
            localStorage.removeItem('ems_temp_data'); // ลบข้อมูลที่เซฟไว้
            
            // เคลียร์ค่าที่แสดงผล
            calculateGCS();
            analyzeVitalSigns();
            calculateDistances();
            showToast("ล้างข้อมูลฟอร์มแล้ว", "info");
            closeConfirmModal();
        }
    </script>

</body></html>
